APP_NAME=Advanced Business RAG Chatbot API
APP_VERSION=0.3.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_ECHO=false
JWT_SECRET_KEY=change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
WIDGET_PUBLIC_API_BASE_URL=http://localhost:8000
WIDGET_SCRIPT_URL=http://localhost:3000/widget.js
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-secret
OPENAI_API_KEY=your_openai_api_key
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
REDIS_URL=redis://localhost:6379/0
TASK_QUEUE_ENABLED=false
TASK_QUEUE_NAME=rag-tasks
TASK_QUEUE_TIMEOUT_SECONDS=5
WORKER_MODE=inline
ALLOW_DESTRUCTIVE_MIGRATIONS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=16
OPENAI_MAX_RETRIES=4
OPENAI_RERANKER_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
VOICE_DEFAULT_TTS_FORMAT=mp3
VOICE_BACKEND_INPUT_PROVIDER=openai
VOICE_BACKEND_OUTPUT_PROVIDER=openai
DATABASE_URL=postgresql://rag_admin:rag_password@localhost:5432/rag_chatbot
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_DISTANCE_METRIC=Cosine
STORAGE_DIR=../storage/uploads
MAX_UPLOAD_SIZE_MB=10
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_KEYWORD_TOP_K=20
RETRIEVAL_HYBRID_TOP_K=10
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_CONTEXT_TOKEN_LIMIT=3200
WEBSITE_CRAWLER_MAX_PAGES=25
WEBSITE_CRAWLER_MAX_DEPTH=1
WEBSITE_CRAWLER_TIMEOUT_SECONDS=15
WEBSITE_CRAWLER_REQUEST_DELAY_SECONDS=0.6
WEBSITE_CRAWLER_MAX_PARALLEL_REQUESTS=3
WEBSITE_CRAWLER_USER_AGENT=AdvancedBusinessRAGBot/1.0
CHAT_RECENT_MESSAGE_LIMIT=8
CHAT_MEMORY_TOKEN_LIMIT=1800
CHAT_SUMMARY_TRIGGER_MESSAGE_COUNT=12
LEAD_CAPTURE_DEFAULT_AFTER_MESSAGES=4
LEAD_CAPTURE_MANUAL_HANDOFF_TEXT=Would you like a human expert to contact you?
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=noreply@example.com
ADMIN_NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_PROVIDER=auto
NOTIFICATION_EMAIL_TIMEOUT_SECONDS=15
NOTIFICATION_EMAIL_MAX_RETRIES=3
NOTIFICATION_EMAIL_RETRY_BACKOFF_SECONDS=1.5
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10
NOTIFICATION_WEBHOOK_MAX_RETRIES=3
NOTIFICATION_WEBHOOK_RETRY_BACKOFF_SECONDS=1.0
NOTIFICATION_QUEUE_POLL_INTERVAL_SECONDS=1.0
NOTIFICATION_QUEUE_BATCH_SIZE=10
NOTIFICATION_QUEUE_ENABLED=true
INTEGRATION_QUEUE_POLL_INTERVAL_SECONDS=1.0
INTEGRATION_QUEUE_BATCH_SIZE=10
INTEGRATION_QUEUE_ENABLED=true
INTEGRATION_RETRY_BACKOFF_SECONDS=2.0
INTEGRATION_DEFAULT_RATE_LIMIT_COUNT=20
INTEGRATION_DEFAULT_RATE_LIMIT_WINDOW_SECONDS=60
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
AWS_REGION=
AWS_SES_FROM_EMAIL=
STORAGE_BACKEND=local
STORAGE_SIGNED_URL_TTL_SECONDS=900
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SUPABASE_URL=
SUPABASE_BUCKET_NAME=
SUPABASE_SERVICE_ROLE_KEY=

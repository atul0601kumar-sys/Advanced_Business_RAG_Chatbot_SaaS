{
  "name": "frontend",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/run-next-build.mjs",
    "build:widget": "vite build --config widget.vite.config.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:run": "vitest run --coverage",
    "test:failed": "vitest run --coverage --changed"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}

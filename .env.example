APP_ENV=development
NODE_ENV=development
APP_VERSION=0.3.0

POSTGRES_DB=rag_chatbot
POSTGRES_USER=rag_admin
POSTGRES_PASSWORD=rag_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rag_admin:rag_password@localhost:5432/rag_chatbot

QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
